# Force OpenCode to use ONLY this repo's .opencode/ (ignores global/other setups).
# Requires direnv: https://direnv.net/
# Run: direnv allow

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export OPENCODE_CONFIG="${REPO_ROOT}/.opencode/opencode.json"
export OPENCODE_CONFIG_DIR="${REPO_ROOT}/.opencode"
