# Copy this file to .env.local and fill values.
# .env.local is gitignored.

# --- LiteLLM Backend (handles Anthropic <-> OpenAI translation) ---
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_API_KEY=sk-litellm-local-proxy-key

# --- Kimi K2.5 ---
# Model name must match model_name in LiteLLM config.yaml
KIMI_MODEL=kimi-k2.5
KIMI_MAX_TOKENS=16384

# --- GLM-5 ---
# Model name must match model_name in LiteLLM config.yaml
GLM_MODEL=glm-5
GLM_MAX_TOKENS=16384

# --- Per-Provider Model Settings ---
# Temperature: -1 = don't inject (use provider default)
CLAUDE_TEMPERATURE=-1
KIMI_TEMPERATURE=0.7
KIMI_TOP_P=0.95
GLM_TEMPERATURE=0.7

# --- Go Router ---
MODEL_ROUTER_HOST=127.0.0.1
MODEL_ROUTER_PORT=3001
MODEL_ROUTER_BIN=$HOME/bin/claude-model-router
MODEL_ROUTER_LOG=/tmp/claude-model-router.log
